# LLM provider — three options, auto-detected in priority order:
#   1. GitHub Models (preferred)  → set GITHUB_TOKEN to a GitHub PAT with
#      `models:read` scope. Base URL https://models.github.ai/inference.
#      Default model: openai/gpt-4.1. Tool-calling supported.
#   2. Google Gemini              → set GEMINI_API_KEY.
#   3. Groq                       → set GROQ_API_KEY.
#
# LLM_PROVIDER=github  # optional: force "github" / "gemini" / "groq"
GITHUB_TOKEN=your-github-pat-here
# GEMINI_API_KEY=your-gemini-api-key-here
# GROQ_API_KEY=your-groq-api-key-here

# Default models per provider:
#   github → openai/gpt-4.1-mini   (gpt-4.1 full is capped at 8k tokens on
#                                  the free tier, which overflows this
#                                  agent's synthesizer prompt; mini has a
#                                  much larger context and matches quality)
#   gemini → gemini-3.1-flash-lite-preview
#   groq   → qwen/qwen3-32b
# LLM_MODEL=openai/gpt-4.1-mini

LLM_TEMPERATURE=0.7
LLM_TOP_P=0.8
# LLM_MAX_RETRIES=4      # transient 5xx retry budget per call
# LLM_BASE_URL=...       # override only if proxying GitHub Models elsewhere
